# Sao chép các giá trị vào backend/.env khi chạy stack Docker local.
#
# Mailpit — sau: docker compose up -d mailpit
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=dev
SMTP_PASSWORD=dev
EMAIL_FROM=Kotonote Nihongo <noreply@localhost>

# MongoDB — sau: docker compose up -d mongodb
MONGODB_URI=mongodb://localhost:27017/kotonote-nihongo
