# =============================================================================
# Kotonote Nihongo — Backend (.env.example)
# Sao chép: cp .env.example .env
# Dev infra: docker compose up -d  (mongodb, mailpit, minio)
# =============================================================================

NODE_ENV=development
PORT=8000

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
MONGODB_URI=mongodb://localhost:27017/kotonote-nihongo

# -----------------------------------------------------------------------------
# Auth & client
# -----------------------------------------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# Google Sign-In (hướng dẫn: docs/GOOGLE_OAUTH_SETUP.md)
# GOOGLE_CLIENT_ID — bắt buộc: verify ID token từ frontend
# GOOGLE_CLIENT_SECRET — tùy chọn với luồng hiện tại (chưa dùng server-side OAuth code)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# -----------------------------------------------------------------------------
# Email
# Production: Gmail/SendGrid. Dev: Mailpit (docker compose up -d mailpit)
#   SMTP → localhost:1025 | UI → http://localhost:8025
# -----------------------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=dev
SMTP_PASSWORD=dev
EMAIL_FROM=Kotonote Nihongo <noreply@localhost>
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# EMAIL_FROM=Kotonote Nihongo <noreply@kotonote.com>

# -----------------------------------------------------------------------------
# AI (Gemini)
# -----------------------------------------------------------------------------
# Một key: GEMINI_API_KEY=...
# Nhiều key (dev, luân phiên khi hết quota): GEMINI_API_KEYS=key1,key2,key3
GEMINI_API_KEYS=your-gemini-api-key-here
# GEMINI_API_KEY=single-key-fallback
GEMINI_MODEL=gemini-flash-latest

# -----------------------------------------------------------------------------
# Object storage — MinIO (mặc định) hoặc local disk
# docker compose up -d minio minio-init
# Console: http://localhost:9001 (minioadmin / minioadmin)
# -----------------------------------------------------------------------------
# minio | local
STORAGE_DRIVER=minio

MINIO_ENDPOINT=http://localhost:9000
# URL công khai để FE hiển thị ảnh (path-style: endpoint/bucket)
MINIO_PUBLIC_URL=http://localhost:9000/kotonote-uploads
MINIO_BUCKET=kotonote-uploads
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_REGION=us-east-1

# Khớp docker-compose (tuỳ chọn — compose có default)
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=minioadmin

# Lưu file trên disk backend/uploads (không cần MinIO)
# STORAGE_DRIVER=local

# -----------------------------------------------------------------------------
# Thanh toán membership (Việt Nam)
# PAYMENT_PROVIDER: mock | payos
# mock — dev, nút xác nhận giả lập; payos — PayOS thật (cần 3 key bên dưới)
# API_PUBLIC_URL — URL HTTPS backend để PayOS gọi webhook (production bắt buộc)
# -----------------------------------------------------------------------------
PAYMENT_PROVIDER=mock
# API_PUBLIC_URL=https://api.your-domain.com
# PAYOS_CLIENT_ID=
# PAYOS_API_KEY=
# PAYOS_CHECKSUM_KEY=
# Đăng ký webhook lúc server start (production). Dev nên dùng: npm run payos:confirm-webhook
# PAYOS_AUTO_CONFIRM_WEBHOOK=false
# FORCE_PAYOS_LOCAL_WEBHOOK=false
