NODE_ENV=development
PORT=8000
# MongoDB — mặc định local; hoặc `docker compose up -d mongodb`
MONGODB_URI=mongodb://localhost:27017/kotonote-nihongo
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email — production: Gmail/SendGrid; dev: Mailpit (docker compose up -d mailpit)
# Mailpit: SMTP localhost:1025, UI http://localhost:8025
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=dev
SMTP_PASSWORD=dev
EMAIL_FROM=Kotonote Nihongo <noreply@localhost>
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# EMAIL_FROM=Kotonote Nihongo <noreply@kotonote.com>

# AI Configuration (Gemini)
GEMINI_API_KEY=your-gemini-api-key-here
