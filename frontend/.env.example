# API REST — nên dùng URL tuyệt đối để Socket.IO suy ra đúng host:port backend.
VITE_API_URL=http://localhost:8000/api
# Khi VITE_API_URL là đường dẫn tương đối (vd. /api), bắt buộc khai báo origin backend cho WebSocket và ảnh tĩnh (avatar /uploads/...):
# VITE_API_ORIGIN=http://localhost:8000
# Hoặc chỉ định thẳng origin Socket (ưu tiên hơn VITE_API_ORIGIN khi có):
# VITE_SOCKET_ORIGIN=http://localhost:8000
VITE_APP_NAME=Kotonote
