# Dev: dùng proxy Vite (khuyến nghị) — URL tương đối, backend qua proxy
VITE_API_URL=/api
# Origin backend cho proxy (phải khớp PORT trong backend/.env)
VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# Hoặc gọi thẳng backend (không qua proxy):
# VITE_API_URL=http://localhost:8000/api

VITE_APP_NAME=Kotonote
